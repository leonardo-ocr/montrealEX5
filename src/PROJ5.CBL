       IDENTIFICATION DIVISION.
       PROGRAM-ID. BANKUPDT.
       ENVIRONMENT DIVISION.
       CONFIGURATION SECTION.
       SOURCE-COMPUTER. IBM-370.
       OBJECT-COMPUTER. IBM-370.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT ARQ-CLIENTES ASSIGN TO UT-S-ARQCLI
           SELECT ARQ-TRANSAC  ASSIGN TO UT-S-ARQTRX
           SELECT ARQ-CLI-OUT  ASSIGN TO UT-S-CLIUPDT.
           SELECT RELATORIO    ASSIGN TO UR-S-RELAT.
           SELECT ARQ-ERROS    ASSIGN TO UR-S-ERROS.
       DATA DIVISION.
       FILE SECTION.
       
       FD  ARQ-CLIENTES
           LABEL RECORDS ARE STANDARD
           RECORD CONTAINS 44 CHARACTERS
           BLOCK CONTAINS 0 RECORDS.
       01  REG-CLIENTE.
           05 CLI-ID           PIC 9(05).
           05 CLI-NOME         PIC X(30).
           05 CLI-SALDO        PIC 9(09).

       FD  ARQ-TRANSAC
           LABEL RECORDS ARE STANDARD
           RECORD CONTAINS 20 CHARACTERS
           BLOCK CONTAINS 0 RECORDS.
       01  REG-TRANSACAO.
           05 TRX-CLI-ID       PIC 9(05).
           05 TRX-ID           PIC 9(05).
           05 TRX-TIPO         PIC X(01).
           05 TRX-VALOR        PIC 9(09).

       FD  ARQ-CLI-OUT
           LABEL RECORDS ARE STANDARD
           RECORD CONTAINS 44 CHARACTERS
           BLOCK CONTAINS 0 RECORDS.
       01  REG-CLI-OUT         PIC X(44).

       FD  RELATORIO
           LABEL RECORDS ARE OMITTED
           RECORD CONTAINS 80 CHARACTERS.
       01  REG-RELATORIO       PIC X(80).

       FD  ARQ-ERROS
           LABEL RECORDS ARE OMITTED
           RECORD CONTAINS 80 CHARACTERS.
       01  REG-ERRO            PIC X(80).

       WORKING-STORAGE SECTION.
       01  WS-FILE-STATUS.
           05 WS-FS-CLIENTES   PIC X(02) VALUE SPACES.
           05 WS-FS-TRANSAC    PIC X(02) VALUE SPACES.

       01  WS-CONTROLE.
           05 WS-CHAVE-CLI     PIC X(05) VALUE SPACES.
           05 WS-CHAVE-TRX     PIC X(05) VALUE SPACES.

       01  WS-ESTATISTICAS.
           05 WS-TOT-CLI-PROC  PIC 9(06) VALUE ZEROS.
           05 WS-TOT-TRX-PROC  PIC 9(06) VALUE ZEROS.
           05 WS-TOT-CREDITOS  PIC 9(06) VALUE ZEROS.
           05 WS-TOT-DEBITOS   PIC 9(06) VALUE ZEROS.
           05 WS-TOT-ERROS     PIC 9(06) VALUE ZEROS.

       01  WS-CLI-TOTAIS.
           05 WS-CLI-TOT-CRED  PIC 9(09) VALUE ZEROS.
           05 WS-CLI-TOT-DEB   PIC 9(09) VALUE ZEROS.

       01  WS-LINHA-RELAT-1.
           05 FILLER           PIC X(09) VALUE 'CLIENTE: '.
           05 WS-REL-CLI-ID    PIC 9(05).
           05 FILLER           PIC X(66) VALUE SPACES.

       01  WS-LINHA-RELAT-2.
           05 FILLER           PIC X(16) VALUE 'TOTAL CREDITOS: '.
           05 WS-REL-CREDITOS  PIC 9(09).
           05 FILLER           PIC X(55) VALUE SPACES.

       01  WS-LINHA-RELAT-3.
           05 FILLER           PIC X(15) VALUE 'TOTAL DEBITOS: '.
           05 WS-REL-DEBITOS   PIC 9(09).
           05 FILLER           PIC X(56) VALUE SPACES.

       01  WS-LINHA-ERRO.
           05 FILLER           PIC X(06) VALUE 'ERRO: '.
           05 WS-MSG-ERRO      PIC X(35).
           05 FILLER           PIC X(04) VALUE 'ID '.
           05 WS-ID-ERRO       PIC 9(05).
           05 FILLER           PIC X(30) VALUE SPACES.

       01  WS-LINHA-ESTAT.
           05 WS-DESC-ESTAT    PIC X(25).
           05 WS-VALOR-ESTAT   PIC 9(06).
           05 FILLER           PIC X(49) VALUE SPACES.

       PROCEDURE DIVISION.
       
       0000-PRINCIPAL SECTION.
           PERFORM 1000-INICIALIZAR.
           PERFORM 2000-LER-CLIENTE.
           PERFORM 3000-LER-TRANSACAO.
           
           PERFORM 4000-MATCH-MERGE
               UNTIL WS-CHAVE-CLI = HIGH-VALUES
                 AND WS-CHAVE-TRX = HIGH-VALUES.
                 
           PERFORM 8000-FINALIZAR.
           STOP RUN.

       1000-INICIALIZAR SECTION.
           OPEN INPUT  ARQ-CLIENTES
                       ARQ-TRANSAC
                OUTPUT ARQ-CLI-OUT
                       RELATORIO
                       ARQ-ERROS.

       2000-LER-CLIENTE SECTION.
           READ ARQ-CLIENTES
               AT END
                   MOVE HIGH-VALUES TO WS-CHAVE-CLI.
           IF WS-CHAVE-CLI NOT = HIGH-VALUES
               MOVE CLI-ID TO WS-CHAVE-CLI
               MOVE ZEROS TO WS-CLI-TOT-CRED
               MOVE ZEROS TO WS-CLI-TOT-DEB.

       3000-LER-TRANSACAO SECTION.
           READ ARQ-TRANSAC
               AT END
                   MOVE HIGH-VALUES TO WS-CHAVE-TRX.
           IF WS-CHAVE-TRX NOT = HIGH-VALUES
               MOVE TRX-CLI-ID TO WS-CHAVE-TRX.

       4000-MATCH-MERGE SECTION.
           IF WS-CHAVE-CLI = WS-CHAVE-TRX
              PERFORM 5000-PROCESSA-TRANSACAO
              PERFORM 3000-LER-TRANSACAO
           ELSE
              IF WS-CHAVE-CLI < WS-CHAVE-TRX
                 PERFORM 6000-GRAVA-CLIENTE
                 PERFORM 2000-LER-CLIENTE
              ELSE
                 PERFORM 7000-ERRO-CLIENTE-INEX
                 PERFORM 3000-LER-TRANSACAO.

       5000-PROCESSA-TRANSACAO SECTION.
           IF TRX-VALOR = ZEROS
              PERFORM 5100-ERRO-VALOR-ZERADO
           ELSE
              IF TRX-TIPO = 'C'
                 PERFORM 5200-PROCESSA-CREDITO
              ELSE
                 IF TRX-TIPO = 'D'
                    PERFORM 5300-PROCESSA-DEBITO
                 ELSE
                    PERFORM 5400-ERRO-TIPO-INV.

       5100-ERRO-VALOR-ZERADO SECTION.
           MOVE 'VALOR DE TRANSACAO INVALIDO - ' TO WS-MSG-ERRO.
           MOVE TRX-CLI-ID TO WS-ID-ERRO.
           WRITE REG-ERRO FROM WS-LINHA-ERRO.
           ADD 1 TO WS-TOT-ERROS.

       5200-PROCESSA-CREDITO SECTION.
           ADD TRX-VALOR TO CLI-SALDO.
           ADD TRX-VALOR TO WS-CLI-TOT-CRED.
           ADD 1 TO WS-TOT-CREDITOS.
           ADD 1 TO WS-TOT-TRX-PROC.

       5300-PROCESSA-DEBITO SECTION.
           IF CLI-SALDO NOT < TRX-VALOR
              SUBTRACT TRX-VALOR FROM CLI-SALDO
              ADD TRX-VALOR TO WS-CLI-TOT-DEB
              ADD 1 TO WS-TOT-DEBITOS
              ADD 1 TO WS-TOT-TRX-PROC
           ELSE
              MOVE 'SALDO INSUFICIENTE - ' TO WS-MSG-ERRO
              MOVE TRX-CLI-ID TO WS-ID-ERRO
              WRITE REG-ERRO FROM WS-LINHA-ERRO
              ADD 1 TO WS-TOT-ERROS.

       5400-ERRO-TIPO-INV SECTION.
           MOVE 'TIPO DE TRANSACAO INVALIDO - ' TO WS-MSG-ERRO.
           MOVE TRX-CLI-ID TO WS-ID-ERRO.
           WRITE REG-ERRO FROM WS-LINHA-ERRO.
           ADD 1 TO WS-TOT-ERROS.

       6000-GRAVA-CLIENTE SECTION.
           WRITE REG-CLI-OUT FROM REG-CLIENTE.
           ADD 1 TO WS-TOT-CLI-PROC.
           
           MOVE CLI-ID TO WS-REL-CLI-ID.
           WRITE REG-RELATORIO FROM WS-LINHA-RELAT-1.
           
           MOVE WS-CLI-TOT-CRED TO WS-REL-CREDITOS.
           WRITE REG-RELATORIO FROM WS-LINHA-RELAT-2.
           
           MOVE WS-CLI-TOT-DEB TO WS-REL-DEBITOS.
           WRITE REG-RELATORIO FROM WS-LINHA-RELAT-3.
           
           MOVE SPACES TO REG-RELATORIO.
           WRITE REG-RELATORIO.

       7000-ERRO-CLIENTE-INEX SECTION.
           MOVE 'CLIENTE NAO ENCONTRADO - ' TO WS-MSG-ERRO.
           MOVE TRX-CLI-ID TO WS-ID-ERRO.
           WRITE REG-ERRO FROM WS-LINHA-ERRO.
           ADD 1 TO WS-TOT-ERROS.

       8000-FINALIZAR SECTION.
           MOVE ALL '*' TO REG-RELATORIO.
           WRITE REG-RELATORIO.
           MOVE 'ESTATISTICAS DE PROCESSAMENTO' TO REG-RELATORIO.
           WRITE REG-RELATORIO.
           MOVE ALL '*' TO REG-RELATORIO.
           WRITE REG-RELATORIO.
           
           MOVE 'CLIENTES PROCESSADOS.....: ' TO WS-DESC-ESTAT.
           MOVE WS-TOT-CLI-PROC TO WS-VALOR-ESTAT.
           WRITE REG-RELATORIO FROM WS-LINHA-ESTAT.

           MOVE 'TRANSACOES PROCESSADAS...: ' TO WS-DESC-ESTAT.
           MOVE WS-TOT-TRX-PROC TO WS-VALOR-ESTAT.
           WRITE REG-RELATORIO FROM WS-LINHA-ESTAT.

           MOVE 'CREDITOS PROCESSADOS.....: ' TO WS-DESC-ESTAT.
           MOVE WS-TOT-CREDITOS TO WS-VALOR-ESTAT.
           WRITE REG-RELATORIO FROM WS-LINHA-ESTAT.

           MOVE 'DEBITOS PROCESSADOS......: ' TO WS-DESC-ESTAT.
           MOVE WS-TOT-DEBITOS TO WS-VALOR-ESTAT.
           WRITE REG-RELATORIO FROM WS-LINHA-ESTAT.

           MOVE 'ERROS ENCONTRADOS........: ' TO WS-DESC-ESTAT.
           MOVE WS-TOT-ERROS TO WS-VALOR-ESTAT.
           WRITE REG-RELATORIO FROM WS-LINHA-ESTAT.

           MOVE 'FIM DO PROCESSAMENTO' TO REG-RELATORIO.
           WRITE REG-RELATORIO.

           CLOSE ARQ-CLIENTES
                 ARQ-TRANSAC
                 ARQ-CLI-OUT
                 RELATORIO
                 ARQ-ERROS.